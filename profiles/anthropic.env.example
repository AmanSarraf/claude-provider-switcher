# profiles/anthropic.env.example
# Anthropic direct API (OAuth subscription or API key)
# Copy to ~/.claude-providers/anthropic.env and fill in your values.
#
# For API key auth, set:
#   export ANTHROPIC_API_KEY="sk-ant-..."
#
# For OAuth subscription (no API key needed), just unset provider-specific vars:

unset CLAUDE_CODE_USE_FOUNDRY
unset ANTHROPIC_FOUNDRY_RESOURCE
unset ANTHROPIC_FOUNDRY_API_KEY
unset ANTHROPIC_DEFAULT_SONNET_MODEL
unset ANTHROPIC_DEFAULT_OPUS_MODEL
unset ANTHROPIC_DEFAULT_HAIKU_MODEL

# Optional: set a specific API key
# export ANTHROPIC_API_KEY="sk-ant-YOUR_KEY_HERE"
