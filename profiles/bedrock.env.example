# profiles/bedrock.env.example
# AWS Bedrock provider for Claude Code
# Copy to ~/.claude-providers/bedrock.env and fill in your values.
#
# Requires AWS credentials with Bedrock access.
# Docs: https://docs.anthropic.com/en/api/claude-on-amazon-bedrock

export CLAUDE_CODE_USE_BEDROCK=1
export AWS_ACCESS_KEY_ID="YOUR_AWS_ACCESS_KEY_ID"
export AWS_SECRET_ACCESS_KEY="YOUR_AWS_SECRET_ACCESS_KEY"
export AWS_REGION="us-east-1"

# Unset other provider vars to avoid conflicts
unset CLAUDE_CODE_USE_FOUNDRY
unset ANTHROPIC_FOUNDRY_RESOURCE
unset ANTHROPIC_FOUNDRY_API_KEY
unset ANTHROPIC_API_KEY
