# profiles/foundry.env.example
# Microsoft Azure AI Foundry provider for Claude Code
# Copy to ~/.claude-providers/foundry.env and fill in your values.
#
# Get these values from your Azure AI Foundry project:
#   https://ai.azure.com → your project → Settings → Keys and Endpoints

export CLAUDE_CODE_USE_FOUNDRY=1
export ANTHROPIC_FOUNDRY_RESOURCE="YOUR_AZURE_RESOURCE_NAME"
export ANTHROPIC_FOUNDRY_API_KEY="YOUR_AZURE_API_KEY"

# Model deployment names — set to your actual Azure deployment names
export ANTHROPIC_DEFAULT_SONNET_MODEL="claude-sonnet-4-5"
export ANTHROPIC_DEFAULT_OPUS_MODEL="claude-opus-4-5"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="claude-haiku-4-5"
