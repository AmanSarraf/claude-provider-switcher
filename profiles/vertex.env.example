# profiles/vertex.env.example
# Google Cloud Vertex AI provider for Claude Code
# Copy to ~/.claude-providers/vertex.env and fill in your values.
#
# Requires a GCP project with Vertex AI API enabled and Claude models activated.
# Docs: https://docs.anthropic.com/en/api/claude-on-vertex-ai

export CLAUDE_CODE_USE_VERTEX=1
export ANTHROPIC_VERTEX_PROJECT_ID="your-gcp-project-id"
export CLOUD_ML_REGION="us-east5"

# Unset other provider vars to avoid conflicts
unset CLAUDE_CODE_USE_FOUNDRY
unset CLAUDE_CODE_USE_BEDROCK
unset ANTHROPIC_FOUNDRY_RESOURCE
unset ANTHROPIC_FOUNDRY_API_KEY
unset ANTHROPIC_API_KEY
unset AWS_ACCESS_KEY_ID
unset AWS_SECRET_ACCESS_KEY
